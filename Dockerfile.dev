FROM node:20-alpine

# 作業ディレクトリ
WORKDIR /app

# better-sqlite3のビルドに必要なパッケージをインストール
RUN apk add --no-cache python3 make g++

# 依存関係のインストール
COPY package*.json ./
RUN npm ci

# ネイティブモジュールを再ビルド（コンテナ環境用）
RUN npm rebuild bcrypt better-sqlite3

# entrypointスクリプトをコピー
COPY docker-entrypoint.sh /usr/local/bin/
RUN chmod +x /usr/local/bin/docker-entrypoint.sh

# アプリケーションファイルをコピー
COPY . .

# ビルド（起動時に環境に応じて実行）
# RUN npm run build

# ポート公開
ARG PORT=3000
EXPOSE ${PORT}

# ENTRYPOINTでネイティブモジュール再ビルドを実行
ENTRYPOINT ["/usr/local/bin/docker-entrypoint.sh"]

# 起動コマンドはdocker-compose.ymlで指定
CMD ["npm", "start"]
