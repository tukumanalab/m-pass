# データベースのパス
DB_PATH=members.db

# アプリケーションURL（メール内のリンクで使用）
APP_URL=http://localhost:3000

# 管理者パスワードのハッシュ値（bcryptでハッシュ化したもの）
# ADMIN_PASSWORD_HASH=$2b$10$eHFkKLHLdUjcLwds5foX..qQ15MU5LY.by7CSpJLIo76BYy4UeK4K

# 管理者アクセスを許可するIPアドレス範囲
# 未設定の場合はプライベートIP（ローカルネットワーク）のみ許可
# 複数指定する場合はカンマ区切り
# 例:
#   ADMIN_ALLOWED_IPS=private              # プライベートIPのみ（デフォルト）
#   ADMIN_ALLOWED_IPS=192.168.1.0/24       # 特定のネットワーク範囲
#   ADMIN_ALLOWED_IPS=192.168.1.100        # 特定のIP
#   ADMIN_ALLOWED_IPS=private,203.0.113.50 # プライベートIP + 特定の外部IP
#   ADMIN_ALLOWED_IPS=*                    # すべて許可（非推奨）
ADMIN_ALLOWED_IPS=private

# Gmail設定（メール送信用 - OAuth2認証）
# Gmail OAuth2認証の設定方法は README.md を参照してください

GMAIL_USER=your-email@gmail.com
GMAIL_CLIENT_ID=your-client-id.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=your-client-secret
GMAIL_REFRESH_TOKEN=your-refresh-token
